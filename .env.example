# --- Saleor App SDK runtime config ---
# Public URL the app is reachable at from Saleor (used in manifest).
# In production this is the Vercel deployment URL or your custom domain.
APP_API_BASE_URL=http://localhost:3100
# Optional. URL used by the Saleor Dashboard to load the app's iframe.
# Usually identical to APP_API_BASE_URL in production.
# APP_IFRAME_BASE_URL=

# Restrict which Saleor instance may install the app. Empty = allow any (dev only).
# SALEOR_API_URL=https://api.infinitybiolabs.com/graphql/

# --- App Persistence Layer (where install tokens live) ---
# `file` for local dev only. Use `upstash` on Vercel (or any serverless host).
APL=file
# Path for FileAPL when APL=file. Defaults to .saleor-app-auth.json.
# APL_FILE_PATH=

# Required when APL=upstash. From upstash.com → your Redis DB → REST API.
# UPSTASH_URL=https://<region>-<id>.upstash.io
# UPSTASH_TOKEN=

# --- ShipStation v2 credentials (https://app.shipstation.com/settings/api) ---
# Single API key — v2 does NOT use a separate secret.
SHIPSTATION_API_KEY=

# Shared secret ShipStation includes as a custom header on outbound webhooks.
# Generate with: openssl rand -hex 32
# Configured into the ShipStation webhook's `headers` array at creation time.
SHIPSTATION_WEBHOOK_TOKEN=
# Header name ShipStation sends the token in. Default: x-webhook-token.
# SHIPSTATION_WEBHOOK_HEADER=x-webhook-token

# --- Logging ---
LOG_LEVEL=info
